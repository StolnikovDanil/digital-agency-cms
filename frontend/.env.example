NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Общий секрет с backend/.env (REVALIDATE_SECRET) — backend дёргает
# POST /api/revalidate с этим секретом после создания/изменения/
# удаления поста, чтобы сбросить ISR-кэш /blog и /blog/:slug сразу,
# а не ждать 60 секунд. Без него src/app/api/revalidate/route.ts
# всегда отвечает 401.
REVALIDATE_SECRET=your-shared-revalidate-secret
JWT_SECRET=your-shared-jwt-secret
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"