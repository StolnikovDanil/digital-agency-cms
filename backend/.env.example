DATABASE_URL=postgresql://user:password@localhost:5432/dbname
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-random-secret-min-32-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
PORT=4000

# Общий секрет с frontend/.env (REVALIDATE_SECRET) — используется,
# чтобы дёргать /api/revalidate на Next.js после создания/изменения/
# удаления поста. Без него backend/src/lib/revalidate.ts просто
# пропускает ревалидацию (см. warn в консоли), а новые статьи будут
# появляться на фронте только после следующего окна ISR.
REVALIDATE_SECRET=your-shared-revalidate-secret

# Пароль в открытом виде, соответствующий ADMIN_PASSWORD_HASH.
# Нужен только для логина в тестах (backend/tests/posts.test.ts),
# в проде не используется.
ADMIN_TEST_PASSWORD=your-plain-text-password-here